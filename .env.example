# seats.aero Pro Partner API key
SEATSAERO_API_KEY=

# Alerting: pick ntfy OR Pushover (or both).
# ntfy: just publish to a (preferably private) topic URL
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# Pushover (https://pushover.net) — both required if used
PUSHOVER_TOKEN=
PUSHOVER_USER=

# Optional overrides
RESEARCHER_DB_PATH=data/researcher.db
RESEARCHER_LOG_LEVEL=INFO
